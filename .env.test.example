# Copy to .env.test and fill in real keys.
# .env.test is gitignored; this example is safe to commit.

POKEGENTS_E2E_REAL_ACP=1
OPENAI_API_KEY=sk-...
# Optional: leave blank to use Claude Code terminal/subscription auth if available.
ANTHROPIC_API_KEY=

# Optional overrides.
# POKEGENTS_ROOT=/path/to/ccd
# POKEGENTS_CLAUDE_ACP_PATH=/path/to/ccd/dashboard/acp-fork/dist/index.js

# Use an explicit non-Opus Claude model for live E2E. Opus is refused unless POKEGENTS_E2E_ALLOW_OPUS=1.
POKEGENTS_E2E_CLAUDE_MODEL=claude-sonnet-4-6
# Optional: explicit Claude Code config dir for subscription auth fallback.
# POKEGENTS_E2E_CLAUDE_CONFIG_DIR=$HOME/.claude
# Optional: explicit Codex config dir to copy auth/config into isolated test home.
# POKEGENTS_E2E_CODEX_HOME=$CODEX_HOME
# Cool down between live E2E prompts/backend switches to avoid burst limits.
POKEGENTS_E2E_COOLDOWN_SECONDS=15
